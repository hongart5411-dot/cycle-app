# Supabase Postgres connection string (transaction-mode pooler, port 6543).
# Get this from: Supabase Dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler.
# NOTE: this file holds the real secret in .env (which is gitignored). Never commit .env.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# HTTP port (optional, defaults to 3000)
PORT=3000

# Optional shared secret that protects the API. When set, every /api route except
# /api/health requires it (Authorization: Bearer <token> or x-api-key header).
# Leave unset for an open API (e.g. local dev). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
API_TOKEN=

# In-app login credentials. POST /api/login {username,password} returns API_TOKEN
# on match, so the password is never embedded in the client. Set both to enable login.
AUTH_USER=
AUTH_PASS=
